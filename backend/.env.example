# ZAIA RAG Chatbot - Environment Configuration
# Copy this file to .env and update with your values

# ===========================================
# Application Settings
# ===========================================
APP_ENV=production
SECRET_KEY=change-this-to-a-very-long-random-string-at-least-32-chars
API_V1_PREFIX=/api/v1

# ===========================================
# JWT Authentication
# ===========================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ===========================================
# MongoDB
# ===========================================
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=zaia_chatbot

# ===========================================
# Qdrant Vector Database
# ===========================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ===========================================
# Neo4j Graph Database
# ===========================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-this-password

# ===========================================
# Redis Cache
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# LLM API (DeepSeek)
# ===========================================
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ===========================================
# Embeddings
# ===========================================
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_PER_MINUTE=60

# ===========================================
# File Upload
# ===========================================
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.docx,.txt,.csv,.md
